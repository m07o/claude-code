# === Proxy Configuration ===
PORT=3002

# === Groq API ===
GROQ_API_KEY=your_groq_api_key_here

# === Default Groq Model ===
# You can use ANY Groq model name here. No restrictions.
# Examples: llama-3.3-70b-versatile, llama-3.1-8b-instant, meta-llama/llama-4-scout-17b-16e-instruct, qwen/qwen3-32b, mixtral-8x7b-32768, gemma2-9b-it
# To change model, just edit this value and restart the proxy.
DEFAULT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# === Local Model (Ollama) ===
# Set LOCAL_MODEL_ENABLED=true to enable local model support
LOCAL_MODEL_ENABLED=true
LOCAL_MODEL_URL=http://localhost:11434/v1/chat/completions
LOCAL_MODEL_NAME=llama3.2:1b

# === Token Limits ===
# Set to 0 for UNLIMITED (no restrictions). The model will use its max context.
MAX_TOKENS=0

# === Debug ===
DEBUG=false

# === Provider Selection ===
# Options: groq, github, local
PROVIDER=groq

# === GitHub Models (free AI models from GitHub) ===
# Get token from: https://github.com/settings/personal-access-tokens/new
# Required permissions: Models (read)
GITHUB_MODELS_TOKEN=your_github_token_here
GITHUB_MODELS_ENABLED=false
